#!/bin/bash
STATE_FILE="${XDG_RUNTIME_DIR:-/tmp}/dictation-state.json"

if [ ! -f "$STATE_FILE" ]; then
    exit 0
fi

PID=$(grep -o '"pid": *[0-9]*' "$STATE_FILE" 2>/dev/null | grep -o '[0-9]*')
if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
    kill "$PID" 2>/dev/null
fi
rm -f "$STATE_FILE"
