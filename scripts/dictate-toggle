#!/bin/bash
STATE_FILE="${XDG_RUNTIME_DIR:-/tmp}/dictation-state.json"

if [ ! -f "$STATE_FILE" ]; then
    notify-send -t 2000 "Dictation" "Daemon not running — starting it..."
    "$HOME/.local/bin/dictate-start" &
    exit 0
fi

PID=$(grep -o '"pid": *[0-9]*' "$STATE_FILE" 2>/dev/null | grep -o '[0-9]*')

if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
    kill -USR1 "$PID"
else
    rm -f "$STATE_FILE"
    notify-send -t 2000 "Dictation" "Daemon not running — starting it..."
    "$HOME/.local/bin/dictate-start" &
fi
